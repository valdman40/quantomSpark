# ─── Mock vs Real API flag ─────────────────────────────────────────────────────
# Set to "true" to call the real New Spark gateway instead of MSW mock data.
# Requires the VITE_GATEWAY_* vars below and a dev-server restart.
VITE_USE_REAL_API=false

# ─── Gateway connection ────────────────────────────────────────────────────────
# IP address of the New Spark gateway (no scheme, no port).
VITE_GATEWAY_IP=172.28.x.x

# Port the gateway web UI listens on (default: 4434).
VITE_GATEWAY_PORT=4434

# URL token — appears in the ?token= query parameter of every platform.cgi call.
# Obtain from the browser's address bar after logging in to the gateway web UI.
VITE_GATEWAY_TOKEN=your_url_token_here

# Full Cookie header value to authenticate gateway requests.
# Browsers cannot set Cookie headers, so this is injected by the Vite proxy.
# Copy the cookie string from the browser DevTools (Network tab → request headers).
# Example: cpa=admin; UTM1Login=d5d128bb5defed1a21e816525f138c8
VITE_GATEWAY_COOKIE=cpa=admin; UTM1Login=your_session_token_here
